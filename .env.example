# ================================
# DB CONFIGURATION (PostgreSQL)
# ================================
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ai_meeting_saas

# ================================
# STORAGE CONFIGURATION (MinIO)
# ================================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AUDIO=audio
MINIO_BUCKET_TRANSCRIPTS=transcripts
MINIO_BUCKET_ANALYSIS=analysis

# ================================
# MESSAGE QUEUE (RabbitMQ)
# ================================
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ================================
# REDIS (for Celery Result Backend)
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ================================
# BACKEND CONFIGURATION
# ================================
PORT=3000
NODE_ENV=development
JWT_SECRET=supersecretchangeit
JWT_EXPIRATION=24h

# ================================
# FRONTEND CONFIGURATION
# ================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ================================
# WORKER CONFIGURATION
# ================================
SERVICE_MODE=combined
WORKER_ID=worker-1
ENVIRONMENT=production
DEBUG=false
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/0
GENAI_API_KEY=your-genai-api-key-here
HF_API_KEY=your-hf-api-key-here
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
STORAGE_SECURE=false
ENABLE_FLOWER=true
FLOWER_PORT=5555
FLOWER_HOST=0.0.0.0
