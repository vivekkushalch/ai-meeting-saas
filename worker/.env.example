# AI Meeting Worker Service - Environment Configuration
# Copy this file to .env and update values for your environment

# ================================
# SERVICE CONFIGURATION
# ================================
# Service mode: combined, transcription, ai
SERVICE_MODE=combined

# Worker identifier (unique per worker instance)
WORKER_ID=worker-1

# Environment: development, production
ENVIRONMENT=production

# Enable debug mode (development only)
DEBUG=false

# ================================
# CELERY CONFIGURATION
# ================================
# Message broker URL (Redis or RabbitMQ)
CELERY_BROKER_URL=redis://localhost:6379/0

# Result backend URL (Redis or database)
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Task time limits (seconds)
TASK_SOFT_TIME_LIMIT=1800
TASK_TIME_LIMIT=3600
TASK_MAX_RETRIES=3
TASK_RETRY_BACKOFF=true

# ================================
# WORKER CONFIGURATION
# ================================
# Worker concurrency (number of parallel tasks)
WORKER_CONCURRENCY=2

# Worker prefetch multiplier
WORKER_PREFETCH_MULTIPLIER=1

# Max tasks per worker child process
WORKER_MAX_TASKS_PER_CHILD=1000

# ================================
# STORAGE CONFIGURATION (MinIO)
# ================================
# MinIO endpoint
STORAGE_ENDPOINT=localhost:9000

# MinIO credentials
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# Storage region
STORAGE_REGION=us-east-1

# Use HTTPS for MinIO
STORAGE_SECURE=false

# ================================
# AI SERVICES CONFIGURATION
# ================================
# Google Generative AI API key
GENAI_API_KEY=your-genai-api-key-here

# Hugging Face API key (for speaker diarization)
HF_API_KEY=your-hf-api-key-here

# ================================
# TRANSCRIPTION CONFIGURATION
# ================================
# WhisperX model: tiny, base, small, medium, large
WHISPER_MODEL=base

# Device: auto, cpu, cuda
WHISPER_DEVICE=auto

# ================================
# PROCESSING CONFIGURATION
# ================================
# Temporary directory for processing
TEMP_DIR=./temp

# Maximum file size (bytes) - 100MB default
MAX_FILE_SIZE=104857600

# Allowed audio extensions
ALLOWED_EXTENSIONS=wav,mp3,ogg,m4a,webm

# ================================
# MONITORING CONFIGURATION
# ================================
# Enable Flower monitoring
ENABLE_FLOWER=true

# Flower server configuration
FLOWER_PORT=5555
FLOWER_HOST=0.0.0.0

# Flower basic authentication (username:password)
# FLOWER_BASIC_AUTH=admin:password

# ================================
# EXAMPLE VALUES FOR DIFFERENT SETUPS
# ================================

# Development with local Redis:
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Production with Redis Cluster:
# CELERY_BROKER_URL=redis://redis-cluster:6379/0
# CELERY_RESULT_BACKEND=redis://redis-cluster:6379/0

# Production with RabbitMQ:
# CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Production with PostgreSQL backend (use main application database):
# CELERY_RESULT_BACKEND=db+postgresql://user:password@localhost:5432/ai_meeting_saas

# Production MinIO:
# STORAGE_ENDPOINT=minio.example.com:9000
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_SECURE=true


